		"disabledForeground": "#A090B8",
		"selection.background": "#5ED4E03D",
		"errorForeground": "#FF5470",
		"editor.background": "#1E1028",
		"editor.foreground": "#F0E0F0",
		"editorLineNumber.foreground": "#705880",
		"editorLineNumber.activeForeground": "#5ED4E0",
		"editor.lineHighlightBackground": "#2E1E401F",
		"editor.selectionBackground": "#5ED4E03D",
		"editor.inactiveSelectionBackground": "#5ED4E026",
		"editorCursor.foreground": "#C49BFF",
		"editor.findMatchBackground": "#FF9BB633",
		"editor.findMatchHighlightBackground": "#FF9BB666",
		"editor.findMatchBorder": "#FF5470",
		"editor.wordHighlightBackground": "#C49BFF1A",
		"editor.wordHighlightStrongBackground": "#5ED4E040",
		"merge.currentHeaderBackground": "#7FD7B54D",
		"merge.currentContentBackground": "#7FD7B526",
		"merge.incomingHeaderBackground": "#8BA4FF4D",
		"merge.incomingContentBackground": "#8BA4FF26",
		"merge.commonHeaderBackground": "#A090B84D",
		"merge.commonContentBackground": "#A090B826",
		"editorGutter.background": "#1E1028",
		"editorGutter.modifiedBackground": "#FFE4B580",
		"editorGutter.addedBackground": "#7FD7B580",
		"editorGutter.deletedBackground": "#FF547080",
		"editorWhitespace.foreground": "#A090B840",
		"editorIndentGuide.background1": "#3A285050",
		"editorIndentGuide.activeBackground1": "#A090B880",
		"editorError.foreground": "#FF5470",
		"editorWarning.foreground": "#FFE4B5",
		"editorInfo.foreground": "#8BA4FF",
		"editorHint.foreground": "#7AA8C0",
		"activityBar.background": "#160A20",
		"activityBar.foreground": "#C8B0D8",
		"activityBar.inactiveForeground": "#A090B8",
		"activityBar.border": "#3A2850",
		"activityBarBadge.background": "#C49BFF",
		"activityBarBadge.foreground": "#1E1028",
		"sideBar.background": "#160A20",
		"sideBar.foreground": "#F0E0F0",
		"sideBar.border": "#3A2850",
		"sideBarSectionHeader.background": "#4A3860",
		"sideBarSectionHeader.foreground": "#C8B0D8",
		"tab.activeBackground": "#1E1028",
		"tab.inactiveBackground": "#160A20",
		"tab.activeForeground": "#F0E0F0",
		"tab.inactiveForeground": "#A090B8",
		"tab.border": "#3A2850",
		"tab.activeBorderTop": "#C49BFF",
		"editorGroupHeader.tabsBackground": "#160A20",
		"editorGroupHeader.tabsBorder": "#3A2850",
		"titleBar.activeBackground": "#160A20",
		"titleBar.activeForeground": "#F0E0F0",
		"titleBar.inactiveBackground": "#0D0612",
		"titleBar.inactiveForeground": "#A090B8",
		"titleBar.border": "#3A2850",
		"statusBar.background": "#0D0612",
		"statusBar.foreground": "#C8B0D8",
		"panel.background": "#160A20",
		"panel.border": "#3A2850",
		"panelTitle.activeForeground": "#F0E0F0",
		"panelTitle.inactiveForeground": "#A090B8",
		"scrollbarSlider.background": "#A090B84C",
		"scrollbarSlider.hoverBackground": "#A090B880",
		"scrollbarSlider.activeBackground": "#C8B0D8B0",
		"terminal.background": "#1E1028",
		"terminal.foreground": "#F0E0F0",
		"terminal.ansiBlack": "#0D0612",
		"terminal.ansiRed": "#FF5470",
		"terminal.ansiGreen": "#7FD7B5",
		"terminal.ansiYellow": "#FFE4B5",
		"terminal.ansiBlue": "#8BA4FF",
		"terminal.ansiMagenta": "#FF7DB0",
		"terminal.ansiCyan": "#5ED4E0",
		"terminal.ansiWhite": "#C8B0D8",
		"terminal.ansiBrightBlack": "#A090B8",
		"terminal.ansiBrightRed": "#FF768D",
		"terminal.ansiBrightGreen": "#99DFC4",
		"terminal.ansiBrightYellow": "#FFE9C4",
		"terminal.ansiBrightBlue": "#A2B6FF",
		"terminal.ansiBrightMagenta": "#FF97C0",
		"terminal.ansiBrightCyan": "#7EDDE6",
		"terminal.ansiBrightWhite": "#D3C0E0",
		"input.background": "#2E1E40",
		"input.foreground": "#F0E0F0",
		"input.border": "#3A2850",
		"input.placeholderForeground": "#A090B8",
		"button.background": "#C49BFF",
		"button.foreground": "#1E1028",
		"button.hoverBackground": "#C49BFFDD",
		"badge.foreground": "#1E1028",
		"badge.background": "#C49BFF",
		"progressBar.background": "#C49BFF",
		"textLink.foreground": "#7AC8FF",
		"textLink.activeForeground": "#7AC8FF",
		"minimap.findMatchHighlight": "#FF9BB6",
		"minimap.selectionHighlight": "#5ED4E03D",
		"editorBracketHighlight.foreground1": "#C49BFF",
		"editorBracketHighlight.foreground2": "#5ED4E0",
		"editorBracketHighlight.foreground3": "#FF9BB6",
		"editorBracketHighlight.foreground4": "#7AC8FF",
		"editorBracketHighlight.foreground5": "#FFA07A",
		"editorBracketHighlight.foreground6": "#7FD7B5"
	},
	"tokenColors": [
		{
			"name": "Comment",
			"scope": [
				"comment",
				"comment.block",
				"comment.line",
				"comment.line.double-slash",
				"comment.line.number-sign",
				"comment.triple-slash"
			],
			"settings": {
				"foreground": "#705880",
				"fontStyle": "italic"
			}
		},
		{
			"name": "String",
			"scope": [
				"string",
				"string.quoted.double",
				"string.quoted.single",
				"string.quoted.triple",
				"string.unquoted",
				"string.regexp"
			],
			"settings": {
				"foreground": "#7FD7B5"
			}
		},
		{
			"name": "String Escape",
			"scope": [
				"constant.character.escape",
				"constant.character.escape.backslash"
			],
			"settings": {
				"foreground": "#7FD7B5"
			}
		},
		{
			"name": "Number",
			"scope": [
				"constant.numeric",
				"constant.numeric.float",
				"constant.numeric.integer",
				"constant.numeric.hex",
				"constant.numeric.octal",
				"constant.numeric.binary"
			],
			"settings": {
				"foreground": "#FFA07A"
			}
		},
		{
			"name": "Boolean",
			"scope": [
				"constant.language.boolean",
				"constant.language.true",
				"constant.language.false"
			],
			"settings": {
				"foreground": "#FFA07A"
			}
		},
		{
			"name": "Constant",
			"scope": [
				"constant",
				"constant.language",
				"constant.language.null",
				"constant.language.undefined",
				"constant.language.nan"
			],
			"settings": {
				"foreground": "#FFA07A"
			}
		},
		{
			"name": "Keyword",
			"scope": [
				"keyword",
				"keyword.control",
				"keyword.control.import",
				"keyword.control.from",
				"keyword.control.export",
				"keyword.control.return",
				"keyword.control.flow",
				"keyword.control.conditional",
				"keyword.control.loop"
			],
			"settings": {
				"foreground": "#FF9BB6"
			}
		},
		{
			"name": "Keyword Operator",
			"scope": [
				"keyword.operator",
				"keyword.operator.arithmetic",
				"keyword.operator.assignment",
				"keyword.operator.comparison",
				"keyword.operator.logical",
				"keyword.operator.new",
				"keyword.operator.expression"
			],
			"settings": {
				"foreground": "#D48BA0"
			}
		},
		{
			"name": "Storage Type",
			"scope": [
				"storage.type",
				"storage.type.class",
				"storage.type.enum",
				"storage.type.interface",
				"storage.type.struct",
				"storage.type.function",
				"storage.type.method"
			],
			"settings": {
				"foreground": "#FFA07A"
			}
		},
		{
			"name": "Storage Modifier",
			"scope": [
				"storage.modifier",
				"storage.modifier.async",
				"storage.modifier.const",
				"storage.modifier.static",
				"storage.modifier.abstract",
				"storage.modifier.readonly",
				"storage.modifier.mutable",
				"storage.modifier.private",
				"storage.modifier.public",
				"storage.modifier.protected"
			],
			"settings": {
				"foreground": "#C49BFF"
			}
		},
		{
			"name": "Function",
			"scope": [
				"entity.name.function",
				"support.function",
				"meta.function-call",
				"meta.method-call"
			],
			"settings": {
				"foreground": "#8BA4FF"
			}
		},
		{
			"name": "Method",
			"scope": ["entity.name.function.member", "meta.method"],
			"settings": {
				"foreground": "#7AC8FF"
			}
		},
		{
			"name": "Constructor",
			"scope": ["entity.name.function.constructor", "entity.name.type.class"],
			"settings": {
				"foreground": "#8BA4FF"
			}
		},
		{
			"name": "Variable",
			"scope": [
				"variable",
				"variable.other",
				"variable.other.member",
				"variable.other.object",
				"variable.other.constant",
				"meta.var"
			],
			"settings": {
				"foreground": "#F0E0F0"
			}
		},
		{
			"name": "Parameter",
			"scope": ["variable.parameter", "entity.name.variable.parameter"],
			"settings": {
				"foreground": "#D48BA0"
			}
		},
		{
			"name": "Property",
			"scope": [
				"variable.other.property",
				"entity.name.variable.member",
				"meta.property"
			],
			"settings": {
				"foreground": "#5ED4E0"
			}
		},
		{
			"name": "Attribute",
			"scope": [
				"entity.other.attribute",
				"meta.attribute",
				"decorator",
				"meta.decorator"
			],
			"settings": {
				"foreground": "#7AA8C0"
			}
		},
		{
			"name": "Type",
			"scope": [
				"entity.name.type",
				"entity.name.type.class",
				"entity.name.type.enum",
				"entity.name.type.interface",
				"entity.name.type.struct",
				"support.type",
				"support.class",
				"entity.name.type.alias"
			],
			"settings": {
				"foreground": "#FFA07A"
			}
		},
		{
			"name": "Namespace",
			"scope": [
				"entity.name.namespace",
				"entity.name.module",
				"entity.name.package"
			],
			"settings": {
				"foreground": "#FF9BB6"
			}
		},
		{
			"name": "Tag",
			"scope": [
				"entity.name.tag",
				"entity.name.tag.html",
				"entity.name.tag.xml",
				"entity.name.tag.jsx"
			],
			"settings": {
				"foreground": "#7FD7B5"
			}
		},
		{
			"name": "Attribute Name (HTML/JSX)",
			"scope": [
				"entity.other.attribute-name",
				"entity.other.attribute-name.html",
				"entity.other.attribute-name.xml",
				"entity.other.attribute-name.jsx",
				"entity.other.attribute-name.css"
			],
			"settings": {
				"foreground": "#FFE4B5"
			}
		},
		{
			"name": "Selector",
			"scope": ["entity.name.selector", "meta.selector"],
			"settings": {
				"foreground": "#FFE4B5"
			}
		},
		{
			"name": "Punctuation",
			"scope": [
				"punctuation",
				"punctuation.terminator",
				"punctuation.separator",
				"punctuation.separator.colon",
				"punctuation.separator.comma",
				"punctuation.separator.dot",
				"punctuation.separator.arrow",
				"punctuation.separator.key-value",
				"punctuation.section"
			],
			"settings": {
				"foreground": "#F0E0F0"
			}
		},
		{
			"name": "Bracket",
			"scope": [
				"punctuation.section.brackets",
				"punctuation.section.parens",
				"punctuation.section.braces",
				"meta.brace",
				"punctuation.definition.brackets",
				"punctuation.definition.parens",
				"punctuation.definition.braces"
			],
			"settings": {
				"foreground": "#F0E0F0"
			}
		},
		{
			"name": "Operator",
			"scope": [
				"keyword.operator",
				"keyword.operator.arithmetic",
				"keyword.operator.assignment",
				"keyword.operator.comparison",
				"keyword.operator.logical"
			],
			"settings": {
				"foreground": "#D48BA0"
			}
		},
		{
			"name": "Preprocessor",
			"scope": [
				"keyword.control.directive",
				"meta.preprocessor",
				"meta.preprocessor.directive",
				"keyword.control.preprocessor"
			],
			"settings": {
				"foreground": "#FF9BB6"
			}
		},
		{
			"name": "URL/Link",
			"scope": [
				"string.other.link",
				"markup.underline.link",
				"constant.other.reference.link"
			],
			"settings": {
				"foreground": "#8BA4FF"
			}
		},
		{
			"name": "Heading",
			"scope": ["markup.heading", "entity.name.section", "heading"],
			"settings": {
				"foreground": "#FFE4B5"
			}
		},
		{
			"name": "Bold",
			"scope": ["markup.bold"],
			"settings": {
				"foreground": "#FFE4B5"
			}
		},
		{
			"name": "Italic",
			"scope": ["markup.italic"],
			"settings": {
				"foreground": "#8BA4FF"
			}
		},
		{
			"name": "Deprecated",
			"scope": ["markup.deleted", "markup.strikethrough", "meta.deprecated"],
			"settings": {
				"foreground": "#FF5470"
			}
		},
		{
			"name": "Invalid",
			"scope": ["invalid", "invalid.illegal", "invalid.deprecated"],
			"settings": {
				"foreground": "#FF5470"
			}
		}
	]
}
