{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "Synthpunk Syntax Schema",
  "required": ["info"],
  "properties": {
    "info": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "version": { "type": "string" }
      }
    },
    "keywords": {
      "type": "object",
      "properties": {
        "keyword": { "type": "string" },
        "control": { "type": "string" },
        "operator": { "type": "string" }
      }
    },
    "storage": {
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "modifier": { "type": "string" },
        "class": { "type": "string" }
      }
    },
    "literals": {
      "type": "object",
      "properties": {
        "string": { "type": "string" },
        "number": { "type": "string" },
        "boolean": { "type": "string" },
        "constant": { "type": "string" }
      }
    },
    "comments": {
      "type": "object",
      "properties": {
        "line": { "type": "string" },
        "block": { "type": "string" }
      }
    },
    "functions": {
      "type": "object",
      "properties": {
        "function": { "type": "string" },
        "method": { "type": "string" },
        "parameter": { "type": "string" }
      }
    },
    "variables": {
      "type": "object",
      "properties": {
        "variable": { "type": "string" },
        "property": { "type": "string" },
        "attribute": { "type": "string" }
      }
    },
    "entities": {
      "type": "object",
      "properties": {
        "namespace": { "type": "string" },
        "tag": { "type": "string" },
        "attribute": { "type": "string" }
      }
    },
    "support": {
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "class": { "type": "string" },
        "function": { "type": "string" }
      }
    },
    "invalid": {
      "type": "object",
      "properties": {
        "illegal": { "type": "string" },
        "deprecated": { "type": "string" }
      }
    }
  }
}
